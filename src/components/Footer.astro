<style>
	.footer {
		background: var(--color-footer-bg);
		color: rgba(255, 255, 255, 0.85);
		padding: 3.5rem 1.5rem 2rem;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr 1fr 1fr;
		gap: 2.5rem;
	}

	/* Logo & About */
	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin-bottom: 1rem;
	}

	.footer-logo-img {
		width: 52px;
		height: 52px;
		filter: invert(1);
		flex-shrink: 0;
	}

	.footer-logo-text {
		font-family: var(--font-serif);
		font-size: 1.1rem;
		font-weight: 600;
		color: white;
		line-height: 1.3;
	}

	.footer-about {
		font-size: 0.9rem;
		line-height: 1.6;
		margin: 0 0 1.25rem;
		color: rgba(255, 255, 255, 0.7);
	}

	/* Social */
	.footer-social {
		display: flex;
		gap: 0.75rem;
	}

	.footer-social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 1.5px solid rgba(255, 255, 255, 0.4);
		border-radius: 50%;
		color: rgba(255, 255, 255, 0.8);
		transition: color 0.2s, background 0.2s, border-color 0.2s;
	}

	.footer-social-link:hover {
		background: white;
		border-color: white;
		color: var(--color-footer-bg);
	}

	.footer-social-link svg {
		width: 20px;
		height: 20px;
	}

	/* Headings */
	.footer-heading {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-weight: 600;
		color: white;
		margin: 0 0 0.85rem;
	}

	.footer-heading-second {
		margin-top: 1.5rem;
	}

	/* Lists */
	.footer-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-list li {
		margin-bottom: 0.45rem;
	}

	.footer-list a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.2s;
	}

	.footer-list a:hover {
		color: white;
	}

	/* Contact list with icons */
	.footer-contact-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.footer-contact-list svg {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
		margin-top: 2px;
		color: var(--color-accent);
	}

	.footer-contact-list a {
		line-height: 1.5;
	}

	/* Hours table */
	.footer-hours {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	.footer-hours td {
		padding: 0.3rem 0;
		vertical-align: top;
	}

	.footer-hours td:first-child {
		color: rgba(255, 255, 255, 0.7);
		padding-right: 1rem;
		white-space: nowrap;
	}

	.footer-hours td:last-child {
		color: rgba(255, 255, 255, 0.9);
		text-align: right;
		white-space: nowrap;
	}

	.footer-hours .closed {
		color: rgba(255, 255, 255, 0.4);
	}

	/* Bottom bar */
	.footer-bottom {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer-copy,
	.footer-credit {
		font-size: 0.82rem;
		color: rgba(255, 255, 255, 0.45);
		margin: 0;
	}

	/* Mobile */
	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}
	}

	@media (max-width: 540px) {
		.footer {
			padding: 2.5rem 1.25rem 1.5rem;
		}

		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.footer-bottom {
			flex-direction: column;
			text-align: center;
			gap: 0.25rem;
		}
	}
</style>
